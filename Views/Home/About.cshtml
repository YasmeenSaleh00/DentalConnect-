@{ ViewData["Title"] = "About DentBridge"; }

<div class="db-hero" style="padding:4rem 0">
    <div class="container db-hero-content text-center">
        <h1>About <span class="gradient-text">DentBridge</span></h1>
        <p class="lead" style="color:rgba(255,255,255,.75);max-width:600px;margin:0 auto">
            Bridging the gap between dental education and accessible patient care.
        </p>
    </div>
</div>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="db-card p-5">
                <h3 class="fw-700 mb-4">Our Mission</h3>
                <p class="text-muted">
                    DentBridge was founded with a simple but powerful idea: 5th-year dental students have the
                    skills, supervision, and time to provide quality dental care — and many patients need
                    affordable access to exactly that care.
                </p>
                <p class="text-muted">
                    We built a platform that connects these two groups seamlessly, creating a win-win for
                    dental education and public health.
                </p>

                <div class="row g-4 mt-3">
                    @foreach (var val in new[] {
                        ("bi-shield-check", "Safe & Supervised", "All treatments occur under certified dental faculty supervision."),
                        ("bi-people-fill", "Community First", "We prioritize access to care for underserved communities."),
                        ("bi-mortarboard", "Education Focused", "Helping students build real-world clinical experience."),
                    })
                    {
                        <div class="col-md-4 text-center">
                            <div class="step-circle" style="width:50px;height:50px;font-size:1.2rem"><i class="bi @val.Item1"></i></div>
                            <h6 class="fw-600 mt-2">@val.Item2</h6>
                            <p class="text-muted small">@val.Item3</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
