@model DentBridge.ViewModels.Case.StudentDashboardViewModel
@using DentBridge.Models.Enums
@{ ViewData["Title"] = "Student Dashboard"; }

<div class="page-header">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <h1 class="mb-0">Welcome, @(Model.StudentName?.Split(' ')[0] ?? "Student")! 🦷</h1>
                @if (Model.IsApproved)
                {
                    <p class="text-muted mb-0 small">Browse available cases and help patients in need</p>
                }
                else
                {
                    <p class="text-warning mb-0 small">
                        <i class="bi bi-hourglass-split me-1"></i>
                        Account status: <strong>@Model.AccountStatus</strong>
                        @if (Model.AccountStatus == AccountStatus.Pending)
                        {
                            <span>— Application Under Review</span>
                        }
                    </p>
                }
            </div>
            @if (Model.IsApproved)
            {
                <div class="d-flex align-items-center gap-3">
                    <div class="stars">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <i class="bi bi-star@(i <= (int)Model.AverageRating ? "-fill" : "")"></i>
                        }
                        <span class="fw-600 ms-1">@Model.AverageRating.ToString("F1")</span>
                        <span class="text-muted small">(@Model.TotalRatings reviews)</span>
                    </div>
                    <a asp-controller="Student" asp-action="SubmitTestimonial"
                       class="btn btn-outline-primary btn-sm fw-600">
                        <i class="bi bi-chat-quote me-1"></i>Share Review
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<div class="container pb-5">

    @if (!Model.IsApproved)
    {
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="db-card p-5 text-center">
                    @if (Model.AccountStatus == AccountStatus.Pending)
                    {
                        <div style="width:80px;height:80px;border-radius:50%;background:rgba(245,158,11,.1);
                                    color:var(--db-warning);font-size:2.5rem;display:flex;
                                    align-items:center;justify-content:center;margin:0 auto 1.5rem">
                            <i class="bi bi-hourglass-split"></i>
                        </div>
                        <h4 class="fw-700">Application Under Review</h4>
                        <p class="text-muted">Your account is being verified. You'll receive an email once approved (24–48 hours).</p>
                    }
                    else if (Model.AccountStatus == AccountStatus.Rejected)
                    {
                        <div style="width:80px;height:80px;border-radius:50%;background:rgba(239,68,68,.1);
                                    color:var(--db-danger);font-size:2.5rem;display:flex;
                                    align-items:center;justify-content:center;margin:0 auto 1.5rem">
                            <i class="bi bi-x-circle-fill"></i>
                        </div>
                        <h4 class="fw-700">Application Not Approved</h4>
                        <p class="text-muted">Please contact support to learn more or resubmit your application with updated documents.</p>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Stats -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-icon cyan"><i class="bi bi-folder-fill"></i></div>
                    <div>
                        <div class="stat-value">@Model.TotalAccepted</div>
                        <div class="stat-label">Cases Taken</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-icon green"><i class="bi bi-check-circle-fill"></i></div>
                    <div>
                        <div class="stat-value">@Model.TotalCompleted</div>
                        <div class="stat-label">Completed</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-icon yellow"><i class="bi bi-star-fill"></i></div>
                    <div>
                        <div class="stat-value">@Model.AverageRating.ToString("F1")</div>
                        <div class="stat-label">Avg. Rating</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-icon blue"><i class="bi bi-grid-3x3"></i></div>
                    <div>
                        <div class="stat-value">@Model.AvailableCases.Count()</div>
                        <div class="stat-label">Available Cases</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Search & Filter -->
        <div class="db-card p-3 mb-4">
            <form asp-action="Dashboard" method="get" class="d-flex flex-wrap gap-2 align-items-end">
                <div class="flex-grow-1">
                    <input type="text" name="search" value="@Model.SearchTerm" class="form-control"
                           placeholder="Search cases by title, description, location..." />
                </div>
                <div>
                    <select name="type" class="form-select">
                        <option value="">All Treatment Types</option>
                        @foreach (var t in Enum.GetValues<TreatmentType>())
                        {
                            <option value="@t" selected="@(Model.FilterType == t)">@t</option>
                        }
                    </select>
                </div>
                <button type="submit" class="btn btn-primary px-3">
                    <i class="bi bi-search me-1"></i>Filter
                </button>
                @if (Model.FilterType.HasValue || !string.IsNullOrEmpty(Model.SearchTerm))
                {
                    <a asp-action="Dashboard" class="btn btn-outline-secondary px-3">Clear</a>
                }
            </form>
        </div>

        <!-- Available Cases -->
        <h5 class="fw-600 mb-3">
            Available Cases
            <span class="badge bg-primary ms-2 fw-500">@Model.AvailableCases.Count()</span>
        </h5>

        @if (!Model.AvailableCases.Any())
        {
            <div class="db-card mb-4">
                <div class="empty-state">
                    <div class="empty-state-icon"><i class="bi bi-search"></i></div>
                    <h5 class="fw-600">No cases found</h5>
                    <p class="text-muted small">Try adjusting your filters or check back later.</p>
                </div>
            </div>
        }
        else
        {
            <div class="row g-3 mb-5">
                @foreach (var c in Model.AvailableCases)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="case-card h-100">
                            <span class="case-type-badge db-badge badge-status-open" style="font-size:.7rem">
                                @c.TreatmentType
                            </span>

                            @{
                                var primaryImg = c.Images.FirstOrDefault(i => i.IsPrimary) ?? c.Images.FirstOrDefault();
                            }
                            @if (primaryImg is not null)
                            {
                                <img src="@primaryImg.ImagePath" alt="case"
                                     style="width:100%;height:140px;object-fit:cover;border-radius:8px;margin-bottom:1rem" />
                            }

                            <h6 class="fw-600 mb-2">@c.Title</h6>
                            <p class="text-muted small mb-3"
                               style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">
                                @c.Description
                            </p>

                            <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
                                @if (!string.IsNullOrEmpty(c.Location))
                                {
                                    <span class="text-muted small"><i class="bi bi-geo-alt me-1"></i>@c.Location</span>
                                }
                                @if (!string.IsNullOrEmpty(c.UrgencyLevel) && c.UrgencyLevel != "Normal")
                                {
                                    <span class="db-badge badge-status-cancelled" style="font-size:.65rem">@c.UrgencyLevel</span>
                                }
                                <span class="text-muted small ms-auto">@c.CreatedAt.ToString("dd MMM")</span>
                            </div>

                            <div class="d-flex gap-2">
                                <a asp-controller="Student" asp-action="CaseDetails" asp-route-id="@c.Id"
                                   class="btn btn-outline-primary btn-sm flex-grow-1">
                                    <i class="bi bi-eye me-1"></i>View Details
                                </a>
                                <form asp-controller="Student" asp-action="AcceptCase" asp-route-id="@c.Id"
                                      method="post" class="flex-grow-1">
                                    <button type="submit" class="btn btn-success btn-sm w-100 fw-600"
                                            data-confirm="Accept this case? You will be responsible for contacting the patient.">
                                        <i class="bi bi-check-circle me-1"></i>Accept
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- My Active Cases -->
        @if (Model.MyCases.Any())
        {
            <h5 class="fw-600 mb-3">My Active Cases</h5>
            <div class="db-card">
                <div class="table-responsive">
                    <table class="table db-table mb-0">
                        <thead>
                            <tr>
                                <th>Case</th>
                                <th>Patient</th>
                                <th>Accepted</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model.MyCases)
                            {
                                var sc = c.Status switch {
                                    CaseStatus.InProgress => "badge-status-inprogress",
                                    CaseStatus.Completed => "badge-status-completed",
                                    _ => "badge-status-open"
                                };
                                <tr>
                                    <td class="fw-500">@c.Title</td>
                                    <td class="text-muted small">@c.Patient?.User?.FullName</td>
                                    <td class="text-muted small">@c.AcceptedAt?.ToString("dd MMM")</td>
                                    <td><span class="db-badge @sc">@c.Status</span></td>
                                    <td>
                                        <a asp-action="CaseDetails" asp-route-id="@c.Id"
                                           class="btn btn-sm btn-outline-primary px-2">View</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>
