@model DentBridge.Models.StudentProfile
@{ ViewData["Title"] = "My Profile"; }

<div class="page-header">
    <div class="container d-flex align-items-center justify-content-between">
        <h1><i class="bi bi-person-badge text-primary me-2"></i>My Profile</h1>
        <a asp-action="EditProfile" class="btn btn-primary btn-sm">
            <i class="bi bi-pencil me-1"></i>Edit Profile
        </a>
    </div>
</div>

<div class="container pb-5">
    <div class="row g-4">
        <div class="col-lg-4">
            <div class="db-card p-4 text-center mb-4">
                @if (!string.IsNullOrEmpty(Model.User.AvatarPath))
                {
                    <img src="@Model.User.AvatarPath"
                         class="rounded-circle border mb-3"
                         style="width:80px;height:80px;object-fit:cover;border-color:var(--db-border)!important"
                         alt="@Model.User.FullName" />
                }
                else
                {
                    <div class="avatar-initials-xs mx-auto mb-3" style="width:80px;height:80px;font-size:2rem">
                        @Model.User.FirstName[0]@Model.User.LastName[0]
                    </div>
                }
                <h4 class="fw-700 mb-1">@Model.User.FullName</h4>
                <div class="text-muted small">@Model.User.Email</div>
                <div class="text-muted small">@Model.User.City</div>
                <div class="stars mt-2">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="bi bi-star@(i <= (int)Model.AverageRating ? "-fill" : "")"></i>
                    }
                    <span class="ms-1 fw-600">@Model.AverageRating.ToString("F1")</span>
                    <span class="text-muted small">(@Model.TotalRatings reviews)</span>
                </div>
                <div class="row g-2 mt-3">
                    <div class="col-6">
                        <div class="db-card p-2">
                            <div class="fw-700 text-primary">@Model.AcceptedCases.Count</div>
                            <div class="text-muted" style="font-size:.7rem">Cases Taken</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="db-card p-2">
                            <div class="fw-700 text-success">@Model.CompletedCases</div>
                            <div class="text-muted" style="font-size:.7rem">Completed</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="db-card p-4">
                <h6 class="fw-600 mb-3">Academic Info</h6>
                <table class="table table-sm table-borderless mb-0 small">
                    <tr><td class="text-muted">University</td><td class="fw-500">@Model.UniversityName</td></tr>
                    <tr><td class="text-muted">Student ID</td><td class="fw-500">@Model.StudentId</td></tr>
                    <tr><td class="text-muted">Specialization</td><td class="fw-500">@Model.Specialization</td></tr>
                    <tr><td class="text-muted">Year</td><td class="fw-500">5th Year</td></tr>
                </table>
            </div>
        </div>

        <div class="col-lg-8">
            @if (!string.IsNullOrEmpty(Model.Bio))
            {
                <div class="db-card p-4 mb-4">
                    <h6 class="fw-600 mb-2">About Me</h6>
                    <p class="text-muted mb-0">@Model.Bio</p>
                </div>
            }

            <div class="db-card p-4">
                <h6 class="fw-600 mb-3">Patient Reviews (@Model.Reviews.Count)</h6>
                @if (!Model.Reviews.Any())
                {
                    <div class="empty-state py-3">
                        <div class="empty-state-icon"><i class="bi bi-star"></i></div>
                        <p class="text-muted small">No reviews yet. Complete cases to earn reviews!</p>
                    </div>
                }
                else
                {
                    @foreach (var r in Model.Reviews.OrderByDescending(x => x.CreatedAt))
                    {
                        <div class="py-3 border-bottom">
                            <div class="d-flex align-items-center justify-content-between mb-1">
                                <div class="stars">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bi bi-star@(i <= r.Rating ? "-fill" : "")" style="font-size:.9rem"></i>
                                    }
                                    <span class="fw-600 ms-1 small">@r.Rating/5</span>
                                </div>
                                <small class="text-muted">@r.CreatedAt.ToString("dd MMM yyyy")</small>
                            </div>
                            <div class="fw-500 small mb-1">@(r.Patient?.User?.FullName ?? "Patient")</div>
                            @if (!string.IsNullOrEmpty(r.Comment))
                            {
                                <p class="text-muted small fst-italic mb-1">"@r.Comment"</p>
                            }
                            <div class="d-flex gap-3 small text-muted">
                                @if (r.IsProfessional) { <span><i class="bi bi-check-circle text-success me-1"></i>Professional</span> }
                                @if (r.IsTimely) { <span><i class="bi bi-check-circle text-success me-1"></i>Timely</span> }
                                @if (r.IsRecommended) { <span><i class="bi bi-check-circle text-success me-1"></i>Recommended</span> }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>
