@model DentBridge.Models.PatientProfile
@{ ViewData["Title"] = "My Profile"; }

<div class="page-header">
    <div class="container d-flex align-items-center justify-content-between">
        <h1><i class="bi bi-person-circle text-primary me-2"></i>My Profile</h1>
        <a asp-action="EditProfile" class="btn btn-primary btn-sm">
            <i class="bi bi-pencil me-1"></i>Edit Profile
        </a>
    </div>
</div>

<div class="container pb-5">
    <div class="row g-4">

        <div class="col-lg-4">
            <div class="db-card p-4 text-center mb-4">
                @if (!string.IsNullOrEmpty(Model.User.AvatarPath))
                {
                    <img src="@Model.User.AvatarPath"
                         class="rounded-circle border mb-3"
                         style="width:88px;height:88px;object-fit:cover;border-color:var(--db-border)!important"
                         alt="@Model.User.FullName" />
                }
                else
                {
                    <div class="avatar-initials-xs mx-auto mb-3" style="width:88px;height:88px;font-size:2.2rem">
                        @Model.User.FirstName[0]@Model.User.LastName[0]
                    </div>
                }
                <h4 class="fw-700 mb-1">@Model.User.FullName</h4>
                <div class="text-muted small mb-1">@Model.User.Email</div>
                @if (!string.IsNullOrEmpty(Model.User.City))
                {
                    <div class="text-muted small"><i class="bi bi-geo-alt me-1"></i>@Model.User.City</div>
                }

                <div class="row g-2 mt-3">
                    <div class="col-4">
                        <div class="db-card p-2">
                            <div class="fw-700 text-primary">@Model.Cases.Count</div>
                            <div class="text-muted" style="font-size:.7rem">Total</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="db-card p-2">
                            <div class="fw-700 text-warning">@Model.Cases.Count(c => c.Status == DentBridge.Models.Enums.CaseStatus.InProgress)</div>
                            <div class="text-muted" style="font-size:.7rem">Active</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="db-card p-2">
                            <div class="fw-700 text-success">@Model.Cases.Count(c => c.Status == DentBridge.Models.Enums.CaseStatus.Completed)</div>
                            <div class="text-muted" style="font-size:.7rem">Done</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="db-card p-4">
                <h6 class="fw-600 mb-3"><i class="bi bi-card-list text-primary me-1"></i>Contact Details</h6>
                <ul class="list-unstyled mb-0 small">
                    @if (!string.IsNullOrEmpty(Model.User.PhoneNumber))
                    {
                        <li class="d-flex align-items-center gap-2 mb-2">
                            <span class="ci-icon" style="width:32px;height:32px;font-size:.85rem"><i class="bi bi-telephone"></i></span>
                            <span class="text-muted">@Model.User.PhoneNumber</span>
                        </li>
                    }
                    @if (!string.IsNullOrEmpty(Model.User.PhoneNumber2))
                    {
                        <li class="d-flex align-items-center gap-2 mb-2">
                            <span class="ci-icon" style="width:32px;height:32px;font-size:.85rem"><i class="bi bi-telephone-plus"></i></span>
                            <span class="text-muted">@Model.User.PhoneNumber2</span>
                        </li>
                    }
                    @if (!string.IsNullOrEmpty(Model.User.Address))
                    {
                        <li class="d-flex align-items-center gap-2 mb-2">
                            <span class="ci-icon" style="width:32px;height:32px;font-size:.85rem"><i class="bi bi-house"></i></span>
                            <span class="text-muted">@Model.User.Address</span>
                        </li>
                    }
                    @if (Model.User.DateOfBirth != default)
                    {
                        <li class="d-flex align-items-center gap-2">
                            <span class="ci-icon" style="width:32px;height:32px;font-size:.85rem"><i class="bi bi-calendar3"></i></span>
                            <span class="text-muted">@Model.User.DateOfBirth.ToString("dd MMM yyyy")</span>
                        </li>
                    }
                </ul>
            </div>
        </div>

        <div class="col-lg-8">

            <div class="db-card p-4 mb-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h6 class="fw-600 mb-0"><i class="bi bi-heart-pulse text-primary me-1"></i>Medical Information</h6>
                    <a asp-action="EditProfile" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                </div>

                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="text-muted small mb-1">Blood Type</div>
                        @if (!string.IsNullOrEmpty(Model.BloodType))
                        {
                            <span class="db-badge badge-status-inprogress">@Model.BloodType</span>
                        }
                        else
                        {
                            <span class="text-muted small fst-italic">Not set</span>
                        }
                    </div>
                    <div class="col-sm-6">
                        <div class="text-muted small mb-1">Insurance Provider</div>
                        <div class="fw-500 small">@(string.IsNullOrEmpty(Model.InsuranceProvider) ? "—" : Model.InsuranceProvider)</div>
                    </div>
                    <div class="col-12">
                        <div class="text-muted small mb-1">Allergies</div>
                        <div class="fw-500 small">@(string.IsNullOrEmpty(Model.Allergies) ? "None recorded" : Model.Allergies)</div>
                    </div>
                    <div class="col-12">
                        <div class="text-muted small mb-1">Medical History</div>
                        <p class="fw-500 small mb-0">@(string.IsNullOrEmpty(Model.MedicalHistory) ? "No history recorded." : Model.MedicalHistory)</p>
                    </div>
                </div>
            </div>

            <div class="db-card p-4">
                <h6 class="fw-600 mb-3"><i class="bi bi-exclamation-triangle text-primary me-1"></i>Emergency Contact</h6>
                @if (string.IsNullOrEmpty(Model.EmergencyContactName) && string.IsNullOrEmpty(Model.EmergencyContactPhone))
                {
                    <div class="empty-state py-3">
                        <div class="empty-state-icon" style="width:52px;height:52px;font-size:1.2rem">
                            <i class="bi bi-person-exclamation"></i>
                        </div>
                        <p class="text-muted small mt-2 mb-0">No emergency contact set.</p>
                        <a asp-action="EditProfile" class="btn btn-outline-primary btn-sm mt-2">Add Contact</a>
                    </div>
                }
                else
                {
                    <div class="d-flex align-items-center gap-3">
                        <div class="ci-icon"><i class="bi bi-person-heart"></i></div>
                        <div>
                            <div class="fw-600 small">@Model.EmergencyContactName</div>
                            <div class="text-muted small">@Model.EmergencyContactPhone</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
