@model DentBridge.Models.DentalCase
@using DentBridge.Models.Enums
@{ ViewData["Title"] = Model.Title; }

<div class="page-header">
    <div class="container">
        <div class="d-flex align-items-center gap-3">
            <a asp-controller="Patient" asp-action="Dashboard" class="btn btn-ghost-icon"><i class="bi bi-arrow-left"></i></a>
            <div>
                <h1 class="mb-0">@Model.Title</h1>
                <p class="text-muted mb-0 small">Case #@Model.Id · @Model.CreatedAt.ToString("dd MMM yyyy")</p>
            </div>
        </div>
    </div>
</div>

<div class="container pb-5">
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="db-card p-4 mb-4">
                <h6 class="fw-600 mb-3">Case Description</h6>
                <p>@Model.Description</p>
                @if (!string.IsNullOrEmpty(Model.PatientNotes))
                {
                    <hr>
                    <h6 class="small fw-600 text-muted">YOUR NOTES</h6>
                    <p class="text-muted small">@Model.PatientNotes</p>
                }
            </div>

            @if (Model.Images.Any())
            {
                <div class="db-card p-4 mb-4">
                    <h6 class="fw-600 mb-3"><i class="bi bi-images me-2"></i>Case Images</h6>
                    <div class="row g-2">
                        @foreach (var img in Model.Images)
                        {
                            <div class="col-4">
                                <img src="@img.ImagePath" class="img-fluid rounded-db"
                                     style="height:140px;width:100%;object-fit:cover" />
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Status Timeline -->
            <div class="db-card p-4 mb-4">
                <h6 class="fw-600 mb-3"><i class="bi bi-clock-history me-2"></i>Case Progress</h6>
                @if (!Model.StatusHistory.Any())
                {
                    <p class="text-muted small">Your case is open and waiting for a student to accept it.</p>
                }
                else
                {
                    <div class="db-timeline">
                        <div class="db-timeline-item">
                            <div class="fw-600 small">Case Posted</div>
                            <div class="text-muted" style="font-size:.75rem">@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</div>
                        </div>
                        @foreach (var h in Model.StatusHistory.OrderBy(x => x.ChangedAt))
                        {
                            <div class="db-timeline-item">
                                <div class="fw-600 small">Status Changed to @h.NewStatus</div>
                                @if (!string.IsNullOrEmpty(h.Notes))
                                {
                                    <div class="text-muted small">@h.Notes</div>
                                }
                                <div class="text-muted" style="font-size:.75rem">@h.ChangedAt.ToString("dd MMM yyyy HH:mm")</div>
                            </div>
                        }
                    </div>
                }
            </div>

            @if (Model.Review is not null)
            {
                <div class="db-card p-4">
                    <h6 class="fw-600 mb-2"><i class="bi bi-star-fill text-warning me-2"></i>Your Review</h6>
                    <div class="stars mb-1">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <i class="bi bi-star@(i <= Model.Review.Rating ? "-fill" : "")"></i>
                        }
                        <span class="fw-600 ms-2">@Model.Review.Rating/5</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Review.Comment))
                    {
                        <p class="text-muted fst-italic">"@Model.Review.Comment"</p>
                    }
                </div>
            }
        </div>

        <div class="col-lg-4">
            @{
                var sc = Model.Status switch {
                    CaseStatus.Open => "badge-status-open",
                    CaseStatus.InProgress => "badge-status-inprogress",
                    CaseStatus.Completed => "badge-status-completed",
                    _ => "badge-status-cancelled"
                };
            }
            <div class="db-card p-4 mb-4">
                <h6 class="fw-600 mb-3">Status</h6>
                <span class="db-badge @sc fs-6">@Model.Status</span>
                @if (Model.AppointmentDate.HasValue)
                {
                    <div class="mt-3 text-muted small">
                        <i class="bi bi-calendar me-1"></i>Preferred: @Model.AppointmentDate.Value.ToString("dd MMM yyyy")
                    </div>
                }
            </div>

            @if (Model.AssignedStudent is not null)
            {
                <div class="db-card p-4 mb-4">
                    <h6 class="fw-600 mb-3">Your Student Dentist</h6>
                    <div class="d-flex gap-3 align-items-center mb-2">
                        <div class="avatar-initials-xs" style="width:42px;height:42px;font-size:1rem">
                            @Model.AssignedStudent.User.FirstName[0]@Model.AssignedStudent.User.LastName[0]
                        </div>
                        <div>
                            <div class="fw-600">@Model.AssignedStudent.User.FullName</div>
                            <div class="text-muted small">@Model.AssignedStudent.UniversityName</div>
                        </div>
                    </div>
                    <div class="stars small">
                        @Model.AssignedStudent.AverageRating.ToString("F1")★
                        <span class="text-muted">(@Model.AssignedStudent.TotalRatings reviews)</span>
                    </div>
                    <div class="mt-2 text-muted small">
                        <i class="bi bi-telephone me-1"></i>@Model.AssignedStudent.User.PhoneNumber
                    </div>
                </div>
            }

            @if (Model.Status == CaseStatus.Completed && Model.Review is null)
            {
                <a asp-controller="Patient" asp-action="Review" asp-route-id="@Model.Id"
                   class="btn btn-warning w-100 fw-600 py-2">
                    <i class="bi bi-star me-2"></i>Leave a Review
                </a>
            }
        </div>
    </div>
</div>
