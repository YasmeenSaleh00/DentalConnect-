@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using DentBridge.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject DentBridge.Data.ApplicationDbContext Db

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – DentBridge</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/dentbridge.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
</head>
<body class="@(Context.Request.Path.Value == "/" || (Context.Request.Path.Value ?? "").Equals("/Home/Index", StringComparison.OrdinalIgnoreCase) ? "home-page" : "")">

@{
    var user = SignInManager.IsSignedIn(User) ? await UserManager.GetUserAsync(User) : null;
    var isAdmin = User.IsInRole("Admin");
    var isStudent = User.IsInRole("Student");
    var isPatient = User.IsInRole("Patient");
    var unreadCount = user is not null
        ? await Db.Notifications.CountAsync(n => n.UserId == user.Id && !n.IsRead)
        : 0;
}

@{
    var reqPath = Context.Request.Path.Value ?? "";
    var isHeroPage = reqPath == "/" || reqPath.Equals("/Home/Index", StringComparison.OrdinalIgnoreCase);
    var navCls = "navbar navbar-expand-lg db-navbar sticky-top" + (isHeroPage ? " db-navbar-hero" : "");
}
    <nav class="@navCls" style="padding-top:0;">
    <div class="container" style="padding-top:0;">
        <a class="navbar-brand db-brand" asp-controller="Home" asp-action="Index">
            <img src="~/images/logo.png" width="40px" height="40px" alt="DentBridge" />
            DentBridge
        </a>
        <button class="navbar-toggler border-0" type="button"
                data-bs-toggle="collapse" data-bs-target="#navMain"
                aria-controls="navMain" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMain">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                @if (!SignInManager.IsSignedIn(User))
                {
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About">About</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="HowItWorks">How It Works</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Contact">Contact Us</a></li>
                }
                @if (isAdmin)
                {
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Admin" asp-action="Index"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Admin" asp-action="PendingStudents"><i class="bi bi-person-check me-1"></i>Approvals</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Admin" asp-action="AllCases"><i class="bi bi-folder2-open me-1"></i>Cases</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Admin" asp-action="AllStudents"><i class="bi bi-mortarboard me-1"></i>Students</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Admin" asp-action="AllUsers"><i class="bi bi-people me-1"></i>Users</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Admin" asp-action="Testimonials"><i class="bi bi-chat-quote me-1"></i>Testimonials</a></li>
                }
                @if (isStudent)
                {
                    <li class="nav-item"><a class="nav-link" asp-controller="Student" asp-action="Dashboard"><i class="bi bi-grid me-1"></i>Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Student" asp-action="MyCases"><i class="bi bi-folder-check me-1"></i>My Cases</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Student" asp-action="Profile"><i class="bi bi-person me-1"></i>Profile</a></li>
                }
                @if (isPatient)
                {
                    <li class="nav-item"><a class="nav-link" asp-controller="Patient" asp-action="Dashboard"><i class="bi bi-grid me-1"></i>Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Patient" asp-action="CreateCase"><i class="bi bi-plus-circle me-1"></i>New Case</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Patient" asp-action="Profile"><i class="bi bi-person me-1"></i>Profile</a></li>
                }
            </ul>
            <div class="d-flex align-items-center gap-2">
                @if (SignInManager.IsSignedIn(User) && user is not null)
                {
                    <a asp-area="@(isAdmin ? "Admin" : "")"
                       asp-controller="@(isAdmin ? "Admin" : isStudent ? "Student" : "Patient")"
                       asp-action="Notifications"
                       class="btn btn-ghost-icon position-relative" title="Notifications">
                        <i class="bi bi-bell fs-5"></i>
                        @if (unreadCount > 0)
                        {
                            <span class="notification-badge">@(unreadCount > 9 ? "9+" : unreadCount.ToString())</span>
                        }
                    </a>
                    <div class="dropdown">
                        <button class="btn btn-user-pill dropdown-toggle" data-bs-toggle="dropdown">
                            @if (!string.IsNullOrEmpty(user.AvatarPath))
                            {
                                <img src="@user.AvatarPath" class="avatar-xs rounded-circle me-1" alt="avatar">
                            }
                            else
                            {
                                <span class="avatar-initials-xs me-1">@user.FirstName[0]@user.LastName[0]</span>
                            }
                            @user.FirstName
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                            <li class="dropdown-header">
                                <div class="fw-600">@user.FullName</div>
                                <small class="text-muted">@user.Email</small>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" data-logout-form>
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="bi bi-box-arrow-right me-2"></i>Sign Out
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-sm px-3">Sign In</a>
                    <div class="dropdown">
                        <button class="btn btn-primary btn-sm px-3 dropdown-toggle" data-bs-toggle="dropdown">Get Started</button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" asp-controller="Account" asp-action="RegisterPatient"><i class="bi bi-person-plus me-2"></i>Register as Patient</a></li>
                            <li><a class="dropdown-item" asp-controller="Account" asp-action="RegisterStudent"><i class="bi bi-mortarboard me-2"></i>Register as Student</a></li>
                        </ul>
                    </div>
                }
            </div>
        </div>
    </div>
</nav>

@{
    var _flashList = new System.Collections.Generic.List<object>();
    if (TempData["Success"] is string _s) _flashList.Add(new { type = "success", text = _s });
    if (TempData["Error"]   is string _e) _flashList.Add(new { type = "error",   text = _e });
    if (TempData["Warning"] is string _w) _flashList.Add(new { type = "warning", text = _w });
    if (TempData["Info"]    is string _i) _flashList.Add(new { type = "info",    text = _i });
}
@if (_flashList.Any())
{
    <script>window.__flashMsgs = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(_flashList));</script>
}

<main>
    @RenderBody()
</main>

<footer class="db-footer mt-5">
    <div class="container">
        <div class="row g-4 py-5">
            <div class="col-lg-4">
                <a class="db-brand text-white text-decoration-none mb-3" asp-controller="Home" asp-action="Index">
                        <img src="~/images/logo.png" width="60px" height="60px" />
                        DentBridge
                </a>
                <p class="text-white-50 small">Connecting 5th-year dental students with patients who need affordable, quality dental care.</p>
            </div>
            <div class="col-lg-2 col-6">
                <h6 class="text-white fw-600 mb-3">Platform</h6>
                <ul class="list-unstyled">
                    <li><a asp-controller="Home" asp-action="HowItWorks" class="footer-link">About Us</a></li>
                    <li><a asp-controller="Home" asp-action="About" class="footer-link">About</a></li>
                    <li><a asp-controller="Home" asp-action="Contact" class="footer-link">Contact Us</a></li>
                    <li><a asp-controller="Account" asp-action="RegisterPatient" class="footer-link">For Patients</a></li>
                    <li><a asp-controller="Account" asp-action="RegisterStudent" class="footer-link">For Students</a></li>
                </ul>
            </div>
            <div class="col-lg-3 col-6">
                <h6 class="text-white fw-600 mb-3">Treatments</h6>
                <ul class="list-unstyled">
                    <li><span class="footer-link">General Dentistry</span></li>
                    <li><span class="footer-link">Orthodontics</span></li>
                    <li><span class="footer-link">Prosthodontics</span></li>
                    <li><span class="footer-link">Oral Surgery</span></li>
                </ul>
            </div>
            <div class="col-lg-3">
                <h6 class="text-white fw-600 mb-3">Contact</h6>
                <p class="text-white-50 small"><i class="bi bi-envelope me-2"></i>
                    <a asp-controller="Home" asp-action="Contact" class="text-white-50 text-decoration-none">Contact Us</a>
                </p>
                <p class="text-white-50 small"><i class="bi bi-telephone me-2"></i>+966 (11) 000-0000</p>
                <div class="d-flex gap-3 mt-3">
                    <a href="#" class="text-white-50 fs-5"><i class="bi bi-twitter-x"></i></a>
                    <a href="#" class="text-white-50 fs-5"><i class="bi bi-linkedin"></i></a>
                    <a href="#" class="text-white-50 fs-5"><i class="bi bi-instagram"></i></a>
                </div>
            </div>
        </div>
        <hr class="border-white border-opacity-10">
        <div class="d-flex flex-wrap justify-content-between align-items-center py-3">
            <p class="text-white-50 small mb-0">© 2026 DentBridge. All rights reserved.</p>
            <div class="d-flex gap-3">
                <a href="#" class="footer-link small">Privacy Policy</a>
                <a href="#" class="footer-link small">Terms of Service</a>
            </div>
        </div>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="~/js/dentbridge.js" asp-append-version="true"></script>
<script>
  (function () {
    var nav = document.querySelector('.db-navbar-hero');
    if (!nav) return;
    function onScroll() {
      nav.classList.toggle('scrolled', window.scrollY > 60);
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
