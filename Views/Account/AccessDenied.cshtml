@{ ViewData["Title"] = "Access Denied"; }

<div class="min-vh-100 d-flex align-items-center" style="background:var(--db-surface)">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 text-center">
                <div style="width:100px;height:100px;border-radius:50%;background:rgba(239,68,68,.1);
                            color:var(--db-danger);font-size:3rem;display:flex;
                            align-items:center;justify-content:center;margin:0 auto 1.5rem">
                    <i class="bi bi-shield-x"></i>
                </div>
                <h1 class="fw-700 mb-3">Access Denied</h1>
                <p class="text-muted mb-4">
                    You don't have permission to access this page. Please sign in with an account that has the required role.
                </p>
                <div class="d-flex justify-content-center gap-3">
                    <a asp-controller="Account" asp-action="Login" class="btn btn-primary px-4">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                    </a>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-house me-2"></i>Go Home
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
