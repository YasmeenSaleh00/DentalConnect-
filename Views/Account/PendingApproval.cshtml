@{ ViewData["Title"] = "Application Submitted"; }

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div style="width:100px;height:100px;border-radius:50%;background:rgba(245,158,11,.1);
                        color:var(--db-warning);font-size:3rem;
                        display:flex;align-items:center;justify-content:center;margin:0 auto 2rem">
                <i class="bi bi-hourglass-split"></i>
            </div>
            <h2 class="fw-700 mb-3">Application Under Review</h2>
            <p class="text-muted mb-4">
                Thank you for applying to DentBridge! Your application and supporting documents
                are being reviewed by our admin team. This typically takes <strong>24–48 hours</strong>.
            </p>
            <div class="db-card p-4 text-start mb-4">
                <h6 class="fw-600 mb-3">What happens next?</h6>
                <div class="db-timeline">
                    <div class="db-timeline-item">
                        <div class="fw-500">Application Submitted</div>
                        <small class="text-muted">Your documents are queued for review</small>
                    </div>
                    <div class="db-timeline-item">
                        <div class="fw-500">Admin Review</div>
                        <small class="text-muted">Our team verifies your student credentials</small>
                    </div>
                    <div class="db-timeline-item">
                        <div class="fw-500">Email Notification</div>
                        <small class="text-muted">You'll receive an email with the decision</small>
                    </div>
                    <div class="db-timeline-item">
                        <div class="fw-500">Account Activated</div>
                        <small class="text-muted">Start browsing and accepting cases!</small>
                    </div>
                </div>
            </div>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4">
                <i class="bi bi-house me-2"></i>Back to Home
            </a>
        </div>
    </div>
</div>
