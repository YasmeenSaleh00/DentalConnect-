@model IEnumerable<DentBridge.Models.Notification>
@{ ViewData["Title"] = "Notifications"; }

<div class="page-header">
    <div class="container">
        <h1><i class="bi bi-bell-fill text-primary me-2"></i>Notifications</h1>
    </div>
</div>

<div class="container pb-5">
    <div class="col-lg-8 mx-auto">
        @if (!Model.Any())
        {
            <div class="db-card">
                <div class="empty-state">
                    <div class="empty-state-icon"><i class="bi bi-bell-slash"></i></div>
                    <h5 class="fw-600">No notifications yet</h5>
                    <p class="text-muted">New case submissions and alerts will appear here.</p>
                </div>
            </div>
        }
        else
        {
            <div class="db-card">
                @foreach (var n in Model)
                {
                    <div class="d-flex gap-3 p-3 border-bottom @(!n.IsRead ? "bg-primary bg-opacity-5" : "")">
                        @{
                            var icon = n.Type switch {
                                DentBridge.Models.Enums.NotificationType.NewCase => "bi-folder-plus text-primary",
                                DentBridge.Models.Enums.NotificationType.AccountApproved => "bi-shield-check text-success",
                                DentBridge.Models.Enums.NotificationType.AccountRejected => "bi-shield-x text-danger",
                                _ => "bi-bell-fill text-primary"
                            };
                        }
                        <div class="stat-icon blue flex-shrink-0" style="width:42px;height:42px">
                            <i class="bi @icon" style="font-size:1rem"></i>
                        </div>
                        <div class="flex-grow-1">
                            <div class="fw-600 small">@n.Title</div>
                            <div class="text-muted small">@n.Message</div>
                            @if (!string.IsNullOrEmpty(n.ActionUrl))
                            {
                                <a href="@n.ActionUrl" class="btn btn-sm btn-outline-primary mt-1 px-2 py-1" style="font-size:.75rem">View</a>
                            }
                        </div>
                        <div class="text-muted text-nowrap" style="font-size:.75rem">
                            @n.CreatedAt.ToString("dd MMM HH:mm")
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
