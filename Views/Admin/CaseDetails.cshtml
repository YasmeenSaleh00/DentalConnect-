@model DentBridge.Models.DentalCase
@using DentBridge.Models.Enums
@{ ViewData["Title"] = "Case #" + Model.Id; }

<div class="page-header">
    <div class="container">
        <div class="d-flex align-items-center gap-3">
            <a asp-action="AllCases" class="btn btn-ghost-icon"><i class="bi bi-arrow-left"></i></a>
            <div>
                <h1 class="mb-0">@Model.Title</h1>
                <p class="text-muted mb-0 small">Case #@Model.Id · Created @Model.CreatedAt.ToString("dd MMM yyyy")</p>
            </div>
        </div>
    </div>
</div>

<div class="container pb-5">
    <div class="row g-4">
        <div class="col-lg-8">

            <!-- Case Info -->
            <div class="db-card p-4 mb-4">
                <h6 class="fw-600 mb-3">Case Description</h6>
                <p class="mb-0">@Model.Description</p>
                @if (!string.IsNullOrEmpty(Model.PatientNotes))
                {
                    <hr>
                    <h6 class="fw-600 mb-2 small text-muted">PATIENT NOTES</h6>
                    <p class="text-muted small">@Model.PatientNotes</p>
                }
            </div>

            <!-- Images -->
            @{
                var beforeImages = Model.Images.Where(i => !i.IsAfterTreatment).ToList();
                var afterImages  = Model.Images.Where(i => i.IsAfterTreatment).ToList();
            }
            @if (beforeImages.Any())
            {
                <div class="db-card p-4 mb-4">
                    <h6 class="fw-600 mb-3"><i class="bi bi-images me-2"></i>Case Images</h6>
                    <div class="row g-2">
                        @foreach (var img in beforeImages)
                        {
                            <div class="col-4">
                                <img src="@img.ImagePath" class="img-fluid rounded-db"
                                     style="height:160px;width:100%;object-fit:cover;cursor:pointer"
                                     data-bs-toggle="modal" data-bs-target="#imgModal"
                                     onclick="document.getElementById('modalImg').src='@img.ImagePath'" />
                            </div>
                        }
                    </div>
                </div>
            }
            @if (afterImages.Any())
            {
                <div class="db-card p-4 mb-4">
                    <h6 class="fw-600 mb-3"><i class="bi bi-camera-fill text-success me-2"></i>After Treatment Images</h6>
                    <div class="row g-2">
                        @foreach (var img in afterImages)
                        {
                            <div class="col-4">
                                <img src="@img.ImagePath" class="img-fluid rounded-db"
                                     style="height:160px;width:100%;object-fit:cover;cursor:pointer"
                                     data-bs-toggle="modal" data-bs-target="#imgModal"
                                     onclick="document.getElementById('modalImg').src='@img.ImagePath'" />
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Status Timeline -->
            <div class="db-card p-4 mb-4">
                <h6 class="fw-600 mb-3"><i class="bi bi-clock-history me-2"></i>Status History</h6>
                @if (!Model.StatusHistory.Any())
                {
                    <p class="text-muted small">No status changes recorded yet.</p>
                }
                else
                {
                    <div class="db-timeline">
                        @foreach (var h in Model.StatusHistory.OrderByDescending(x => x.ChangedAt))
                        {
                            <div class="db-timeline-item">
                                <div class="fw-600 small">@h.OldStatus → @h.NewStatus</div>
                                @if (!string.IsNullOrEmpty(h.Notes))
                                {
                                    <div class="text-muted small">@h.Notes</div>
                                }
                                <div class="text-muted" style="font-size:.75rem">@h.ChangedAt.ToString("dd MMM yyyy HH:mm")</div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Review -->
            @if (Model.Review is not null)
            {
                <div class="db-card p-4">
                    <h6 class="fw-600 mb-3"><i class="bi bi-star-fill text-warning me-2"></i>Patient Review</h6>
                    <div class="stars mb-2">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <i class="bi bi-star@(i <= Model.Review.Rating ? "-fill" : "")"></i>
                        }
                        <span class="fw-600 ms-2">@Model.Review.Rating / 5</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Review.Comment))
                    {
                        <p class="text-muted fst-italic mb-2">"@Model.Review.Comment"</p>
                    }
                    <div class="d-flex gap-3 small">
                        <span class="text-@(Model.Review.IsProfessional ? "success" : "danger")">
                            <i class="bi bi-@(Model.Review.IsProfessional ? "check" : "x")-circle me-1"></i>Professional
                        </span>
                        <span class="text-@(Model.Review.IsTimely ? "success" : "danger")">
                            <i class="bi bi-@(Model.Review.IsTimely ? "check" : "x")-circle me-1"></i>Timely
                        </span>
                        <span class="text-@(Model.Review.IsRecommended ? "success" : "danger")">
                            <i class="bi bi-@(Model.Review.IsRecommended ? "check" : "x")-circle me-1"></i>Recommended
                        </span>
                    </div>
                </div>
            }

        </div>

        <div class="col-lg-4">

            <!-- Patient Info -->
            <div class="db-card p-4 mb-4">
                <h6 class="fw-600 mb-3">Patient</h6>
                <div class="fw-600">@Model.Patient?.User?.FullName</div>
                <div class="text-muted small">@Model.Patient?.User?.Email</div>
                <div class="text-muted small">@Model.Patient?.User?.PhoneNumber</div>
                <div class="text-muted small">@Model.Patient?.User?.City</div>
            </div>

            <!-- Assigned Student -->
            <div class="db-card p-4 mb-4">
                <h6 class="fw-600 mb-3">Assigned Student</h6>
                @if (Model.AssignedStudent is null)
                {
                    <p class="text-muted small">No student assigned yet.</p>
                }
                else
                {
                    <div class="fw-600">@Model.AssignedStudent.User?.FullName</div>
                    <div class="text-muted small">@Model.AssignedStudent.UniversityName</div>
                    <div class="text-muted small">Accepted: @Model.AcceptedAt?.ToString("dd MMM yyyy")</div>
                    <div class="stars small mt-1">
                        @Model.AssignedStudent.AverageRating.ToString("F1")★ (@Model.AssignedStudent.TotalRatings reviews)
                    </div>
                }
            </div>

            <!-- Case Meta -->
            <div class="db-card p-4 mb-4">
                <h6 class="fw-600 mb-3">Case Info</h6>
                <table class="table table-sm table-borderless mb-0 small">
                    <tr><td class="text-muted">Type</td><td class="fw-500">@Model.TreatmentType</td></tr>
                    <tr><td class="text-muted">Urgency</td><td class="fw-500">@(Model.UrgencyLevel ?? "Normal")</td></tr>
                    @if (!string.IsNullOrEmpty(Model.Location))
                    {
                        <tr><td class="text-muted">Location</td><td class="fw-500">@Model.Location</td></tr>
                    }
                    @if (Model.AppointmentDate.HasValue)
                    {
                        <tr><td class="text-muted">Appointment</td><td class="fw-500">@Model.AppointmentDate.Value.ToString("dd MMM yyyy")</td></tr>
                    }
                </table>
            </div>

            <!-- Update Status (Admin) -->
            <div class="db-card p-4">
                <h6 class="fw-600 mb-3"><i class="bi bi-pencil-square me-2"></i>Update Status</h6>
                <form asp-action="UpdateCaseStatus" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="mb-3">
                        <select name="status" class="form-select form-select-sm">
                            @foreach (var s in Enum.GetValues<CaseStatus>())
                            {
                                <option value="@s" selected="@(s == Model.Status)">@s</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <textarea name="notes" class="form-control form-control-sm" rows="2"
                                  placeholder="Admin notes (optional)..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm w-100 fw-600">Update Status</button>
                </form>
            </div>

        </div>
    </div>
</div>

<!-- Image Lightbox Modal -->
<div class="modal fade" id="imgModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content bg-transparent border-0">
            <img id="modalImg" class="img-fluid rounded-db" />
        </div>
    </div>
</div>
